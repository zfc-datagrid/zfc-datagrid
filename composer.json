{
    "name":        "zfc-datagrid/zfc-datagrid",
    "description": "Laminas Module that provides a datagrid for different datasources and output formats",
    "type":        "library",
    "license":     "MIT",
    "keywords": [
        "datagrid",
        "zfc-datagrid",
        "ZfcDatagrid",
        "Datagrid",
        "Datatable",
        "module",
        "laminas",
        "zf",
        "zf3",
        "Zend Framework",
        "pdf",
        "excel",
        "jqgrid",
        "bootstrap",
        "Doctrine"
    ],
    
    "authors": [{
        "name": "Martin Keckeis",
        "email": "martin.keckeis1@gmail.com"
    }],

    "require": {
        "php": "^8.2.0",
        "mezzio/mezzio-router": "@stable",
        "laminas/laminas-session": "^2.26",
        "laminas/laminas-paginator": "^2.5",
        "laminas/laminas-servicemanager": "^3.9",
        "mezzio/mezzio-laminasviewrenderer": "^2.19",
        "laminas/laminas-diactoros": "@stable",
        "doctrine/doctrine-laminas-hydrator": "^2.0 || ^3.0"
    },
    
    "require-dev": {
        "phpunit/phpunit": "^9.5.9",
        "roave/psr-container-doctrine": "^6.0",
        "laminas/laminas-stdlib": "^3.21",
        "laminas/laminas-i18n": "^2.32",

        "phpoffice/phpspreadsheet": "^1.11",
        "tecnickcom/tcpdf": "^6.2"
    },
    
    "suggest" : {
        "ext-intl": "*",
        "doctrine/doctrine-orm-module": "for doctrine support",
        
        "phpoffice/phpspreadsheet": "^1.11 for spreadsheet support",
        "tecnickcom/tcpdf": "^6.2",

        "laminas/laminas-text": "~2.5",
        "laminas/laminas-json": "to support date ranges"
    },

    "extra": {
        "laminas": {
            "config-provider": "ZfcDatagrid\\ConfigProvider",
            "module": "ZfcDatagrid"
        },
        "branch-alias": {
            "dev-master": "1.4-dev",
            "dev-develop": "2.0-dev"
        }
    },

    "autoload": {
        "psr-4": {
            "ZfcDatagrid\\": "src"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "ZfcDatagridTest\\": "tests/ZfcDatagridTest"
        }
    },

    "replace": {
        "thadafinser/zfc-datagrid": "self.version"
    },

    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },

    "scripts": {
        "check": [
            "@cs-check",
            "@test"
        ],
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "test": "phpunit",
        "test-coverage": "phpunit --colors=always --coverage-clover clover.xml",
        "upload-coverage": "vendor/bin/php-coveralls -v"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
