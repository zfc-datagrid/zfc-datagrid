<!-- Start footer -->
<div class="row-fluid row" id="{{ gridId }}_footer">

    <!-- mass actions -->
    <div class="col-md-4">
        {% for action in massActions %}
            <a href="#" class="btn btn-default massAction" data-url="{{ action.getLink() }}">
                {{ translate(action.getTitle()) }}
            </a>
        {% endfor %}
    </div>
    
    <!-- Pagination -->
    <div class="col-md-4 text-center">
        <input type="hidden" name="{{ parameterNames['currentPage'] }}" value="{{ paginator.getPages().current }}" />
        {{ paginationcontrol(paginator, 'Elastic', 'zfc-datagrid/renderer/bootstrapTable/paginator', {
            'activeParameters' : activeParameters,
            'parameterNames' : parameterNames,
            'gridId' : gridId
        })|raw }}
    </div>
    <!-- Info -->
    <div class="col-md-4 text-right">
        {{ translate('Showing') ~ ' ' ~ paginator.getCurrentItemCount() ~ ' ' ~ translate('of') ~ ' ' ~ paginator.getTotalItemCount() ~ ' ' ~ translate('item(s)') }}<br />
        {{ translate('Page') ~ ' ' ~ paginator.getCurrentPageNumber() ~ ' ' ~ translate('of') ~ ' ' ~ paginator.count() }}
    </div>
</div><!-- End footer -->

{% do inlineScript().captureStart() %}
function {{ gridId }}_toggleCheckboxes(element){
    var elements = document.getElementsByName('massActionSelected[]');
    
    var useThis = element.checked;
    for(i = 0; i < elements.length; i++){
        elements[i].checked = useThis;
    }
}

jQuery( document ).ready(function() {
    jQuery('#{{ gridId }}_footer a.massAction').click( function() {
        var form = document.createElement('form');
        form.setAttribute('name', 'massAction');
        form.setAttribute('method', 'post');
        form.setAttribute('action', $(this).attr('data-url'));
        
        var checkboxes = document.getElementsByName('massActionSelected[]');
        for(i = 0; i < checkboxes.length; i++){
            var node = checkboxes[i].cloneNode();
            node.name = '{{ parameterNames['massIds'] }}[]';
            form.appendChild(node);
        }
        
        document.body.appendChild(form);
        form.submit();
        document.body.removeChild(form);
    });

    jQuery('#{{ gridId }} tr').click(function(event) {
        if (event.target.type !== 'checkbox') {
            jQuery(':checkbox', this).trigger('click');
        }
    });
});

{% do inlineScript().captureEnd() %}
